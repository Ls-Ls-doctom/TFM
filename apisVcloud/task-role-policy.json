{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListDataLake",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::REPLACE_BUCKET",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "bronze/*",
            "silver/*",
            "gold/*",
            "reports/*",
            "errors/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadWriteDataLakeLayers",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::REPLACE_BUCKET/bronze/*",
        "arn:aws:s3:::REPLACE_BUCKET/silver/*",
        "arn:aws:s3:::REPLACE_BUCKET/gold/*",
        "arn:aws:s3:::REPLACE_BUCKET/reports/*",
        "arn:aws:s3:::REPLACE_BUCKET/errors/*"
      ]
    }
  ]
}
